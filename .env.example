# PayPal LIVE
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_live_client_id
PAYPAL_CLIENT_SECRET=your_live_secret
PAYPAL_MODE=live
PAYPAL_CURRENCY=ZAR
NEXT_PUBLIC_PAYPAL_CURRENCY=ZAR
# Optional: from PayPal webhook subscription
# PAYPAL_WEBHOOK_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# REQUIRED for matching, job create, webhooks (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenAI — AI KYC document scan (+ WhatsApp concierge later)
OPENAI_API_KEY=sk-...
# Optional model override (default gpt-4o-mini; needs vision support)
# OPENAI_MODEL=gpt-4o-mini
# Meta webhook verify token (GET /api/whatsapp/webhook) — Phase 3 later
# WHATSAPP_VERIFY_TOKEN=choose_a_long_random_string
# Later: WHATSAPP_ACCESS_TOKEN=... WHATSAPP_PHONE_NUMBER_ID=...
