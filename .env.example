# PayPal LIVE
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_live_client_id
PAYPAL_CLIENT_SECRET=your_live_secret
PAYPAL_MODE=live
PAYPAL_CURRENCY=ZAR
NEXT_PUBLIC_PAYPAL_CURRENCY=ZAR
# Optional: from PayPal webhook subscription
# PAYPAL_WEBHOOK_ID=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
# REQUIRED for matching, job create, webhooks (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenAI — AI KYC document scan (+ WhatsApp concierge later)
OPENAI_API_KEY=sk-...
# Optional model override (default gpt-4o-mini; needs vision support)
# OPENAI_MODEL=gpt-4o-mini

# Firebase Cloud Messaging (FREE Spark tier) — driver/customer push
# Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Project Settings → Cloud Messaging → Web Push certificates (VAPID)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=
# Project Settings → Service accounts → Generate new private key (server send)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste private_key with \n escaped as \\n in one line
FIREBASE_PRIVATE_KEY=

# Meta webhook verify token (GET /api/whatsapp/webhook) — paused for MVP cost
# WHATSAPP_VERIFY_TOKEN=choose_a_long_random_string
